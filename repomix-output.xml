            <button style={{ width: '100%', background: '#F8FAFC', border: '1px solid #E2E8F0', borderRadius: '8px', padding: '6px', fontSize: '10px', color: '#94A3B8', cursor: 'not-allowed', fontFamily: 'inherit', textAlign: 'center' }}>
